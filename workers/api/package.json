{
	"name": "@repo/api",
	"version": "0.0.5",
	"type": "module",
	"config": {
		"drizzle": "--config=src/config/drizzle.config.ts"
	},
	"scripts": {
		"dev": "wrangler dev --env local",
		"deploy": "wrangler deploy --env staging --minify",
		"deploy:staging": "wrangler deploy --env staging --minify",
		"deploy:production": "wrangler deploy --env production --minify",
		"deploy:dry": "wrangler deploy --env staging --minify --dry-run",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings",
		"kv:create": "wrangler kv namespace create talash-kv && wrangler kv namespace create talash-kv --preview",
		"db:generate": "drizzle-kit generate --config=src/config/drizzle.config.ts",
		"db:studio": "drizzle-kit studio --config=src/config/drizzle.config.ts",
		"db:check": "drizzle-kit check --config=src/config/drizzle.config.ts",
		"db:migrate:local": "wrangler d1 migrations apply TALASH_DB --env local --local",
		"db:migrate:remote": "wrangler d1 migrations apply TALASH_DB --env production",
		"db:migrate:local:test": "wrangler d1 migrations apply TALASH_DB --env test --local",
		"db:migrate:test": "wrangler d1 migrations apply TALASH_DB --env production",
		"lint": "biome check .",
		"format": "biome format . --write",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@repo/core": "workspace:*",
		"@repo/tokens": "workspace:*",
		"@repo/walk-in-sync": "workspace:*",
		"@hono/standard-validator": "^0.2.2",
		"@scalar/hono-api-reference": "^0.9.34",
		"@hono/zod-openapi": "^1.4.0",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.23",
		"qs": "^6.15.2",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@faker-js/faker": "^10.4.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^20.19.41",
		"@types/qs": "^6.15.1",
		"better-sqlite3": "^12.10.0",
		"citty": "^0.2.2",
		"drizzle-kit": "^0.31.10",
		"vitest": "^4.1.8",
		"wrangler": "^4.95.0"
	}
}