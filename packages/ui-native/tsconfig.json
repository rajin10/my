{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"skipLibCheck": true,
		"jsx": "react-jsx",
		"lib": ["ESNext", "DOM"],
		"types": ["react"],
		"noEmit": true
	},
	"include": ["src/**/*.ts", "src/**/*.tsx", "nativewind-env.d.ts"]
}
