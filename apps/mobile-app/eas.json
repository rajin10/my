{
	"cli": {
		"version": ">= 16.0.0",
		"appVersionSource": "remote"
	},
	"build": {
		"base": {
			"bun": "1.3.1",
			"node": "24.11.0",
			"env": {
				"EXPO_PUBLIC_AUTH_PROVIDER": "native"
			}
		},
		"development": {
			"extends": "base",
			"developmentClient": true,
			"distribution": "internal",
			"channel": "development",
			"android": {
				"buildType": "apk"
			},
			"env": {
				"EXPO_PUBLIC_API_URL": "https://api.talash.com.bd"
			}
		},
		"preview": {
			"extends": "base",
			"distribution": "internal",
			"channel": "preview",
			"android": {
				"buildType": "apk"
			},
			"env": {
				"EXPO_PUBLIC_API_URL": "https://api.talash.com.bd"
			}
		},
		"production": {
			"extends": "base",
			"channel": "production",
			"android": {
				"buildType": "app-bundle",
				"autoIncrement": true
			},
			"env": {
				"EXPO_PUBLIC_API_URL": "https://api.talash.bd"
			}
		}
	},
	"submit": {
		"preview": {
			"android": {
				"serviceAccountKeyPath": "./google-play-service-account.json",
				"track": "internal",
				"releaseStatus": "draft"
			}
		},
		"production": {
			"android": {
				"serviceAccountKeyPath": "./google-play-service-account.json",
				"track": "production",
				"releaseStatus": "draft"
			}
		}
	}
}
