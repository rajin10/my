{
	"name": "@repo/owner-app",
	"main": "expo-router/entry",
	"version": "1.0.4",
	"private": true,
	"scripts": {
		"start": "expo start",
		"android": "expo start --android",
		"ios": "expo start --ios",
		"web": "expo start --web",
		"lint": "expo lint",
		"test": "vitest run",
		"test:watch": "vitest",
		"build": "expo export --platform android",
		"build:dev": "eas build -p android --profile development",
		"build:preview": "eas build -p android --profile preview",
		"build:prod": "eas build -p android --profile production",
		"build:android": "eas build -p android --profile production",
		"build:ios": "eas build -p ios",
		"build:development:android": "eas build -p android --profile development",
		"build:development:ios": "eas build -p ios --profile development",
		"build:preview:android": "eas build -p android --profile preview",
		"build:preview:ios": "eas build -p ios --profile preview",
		"update:preview": "eas update --channel preview",
		"update:production": "eas update --channel production",
		"submit:preview": "eas submit -p android --profile preview --latest",
		"submit:production:android": "eas submit -p android --profile production --latest",
		"submit:production:ios": "eas submit -p ios --profile production --latest",
		"submit:preview:android": "eas submit -p android --profile preview --latest",
		"submit:preview:ios": "eas submit -p ios --profile preview --latest",
		"submit:prod": "eas submit -p android --profile production --latest",
		"build-and-submit": "eas build -p android --profile production --auto-submit",
		"update": "eas update --channel production"
	},
	"dependencies": {
		"@expo/ui": "~56.0.15",
		"@react-native-community/netinfo": "12.0.1",
		"@react-native-google-signin/google-signin": "^16.1.2",
		"@repo/api-client": "workspace:*",
		"@repo/mobile-query": "workspace:*",
		"@repo/tokens": "workspace:*",
		"@repo/ui-native": "workspace:*",
		"@repo/walk-in-sync": "workspace:*",
		"@tanstack/react-query": "^5.101.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"expo": "~56.0.8",
		"expo-auth-session": "~56.0.13",
		"expo-build-properties": "~56.0.18",
		"expo-constants": "~56.0.16",
		"expo-dev-client": "~56.0.20",
		"expo-device": "~56.0.4",
		"expo-font": "~56.0.5",
		"expo-glass-effect": "~56.0.4",
		"expo-haptics": "~56.0.3",
		"expo-image": "~56.0.9",
		"expo-image-picker": "^56.0.15",
		"expo-linking": "~56.0.13",
		"expo-notifications": "^56.0.15",
		"expo-router": "~56.2.8",
		"expo-secure-store": "~56.0.4",
		"expo-splash-screen": "~56.0.10",
		"expo-status-bar": "~56.0.4",
		"expo-symbols": "~56.0.5",
		"expo-system-ui": "~56.0.5",
		"expo-updates": "~56.0.19",
		"expo-web-browser": "~56.0.5",
		"lightningcss": "1.30.1",
		"lucide-react-native": "^1.17.0",
		"nativewind": "5.0.0-preview.4",
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"react-native": "0.85.3",
		"react-native-css": "^3.0.1",
