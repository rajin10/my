{
	"name": "talash",
	"version": "0.0.4",
	"description": "A monorepo for Talash's applications and packages",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"packageManager": "bun@1.3.1",
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"dev:setup": "bun scripts/dev-setup.ts",
		"dev:all": "bun scripts/dev-all.ts",
		"api:dev": "turbo run dev --filter=@repo/api",
		"auth-service:dev": "bun run --filter @repo/auth-service dev",
		"lpg-service:dev": "bun run --filter @repo/lpg-service dev",
		"booking-service:dev": "bun run --filter @repo/booking-service dev",
		"api:typegen": "bun run --filter @repo/api cf-typegen",
		"queue:typegen": "bun run --filter @repo/queue cf-typegen",
		"scheduled:typegen": "bun run --filter @repo/scheduled cf-typegen",
		"booking-service:typegen": "bun run --filter @repo/booking-service cf-typegen",
		"marketing-site:typegen": "bun run --filter @repo/marketing-site cf-typegen",
		"business-dashboard:typegen": "bun run --filter @repo/business-dashboard cf-typegen",
		"typegen": "bun run api:typegen && bun run queue:typegen && bun run scheduled:typegen && bun run marketing-site:typegen && bun run business-dashboard:typegen",
		"queue:dev": "turbo run dev --filter=@repo/queue",
		"queue:cf-typegen": "bun run --filter @repo/queue cf-typegen",
		"scheduled:dev": "turbo run dev --filter=@repo/scheduled",
		"scheduled:cf-typegen": "bun run --filter @repo/scheduled cf-typegen",
		"mobile-app:dev": "bun run --filter @repo/mobile-app start",
		"owner-app:dev": "bun run --filter @repo/owner-app start",
		"mobile-app:build:dev": "bun run --filter @repo/mobile-app build:dev",
		"mobile-app:build:preview": "bun run --filter @repo/mobile-app build:preview",
		"mobile-app:build:prod": "bun run --filter @repo/mobile-app build:prod",
		"mobile-app:submit": "bun run --filter @repo/mobile-app submit:prod",
		"mobile-app:submit:preview": "bun run --filter @repo/mobile-app submit:preview",
		"mobile-app:update": "bun run --filter @repo/mobile-app update",
		"owner-app:build:dev": "bun run --filter @repo/owner-app build:dev",
		"owner-app:build:preview": "bun run --filter @repo/owner-app build:preview",
		"owner-app:build:prod": "bun run --filter @repo/owner-app build:prod",
		"owner-app:submit": "bun run --filter @repo/owner-app submit:prod",
		"owner-app:submit:preview": "bun run --filter @repo/owner-app submit:preview",
		"owner-app:update": "bun run --filter @repo/owner-app update",
		"marketing-site:dev": "turbo run dev --filter=@repo/marketing-site",
		"business-dashboard:dev": "turbo run dev --filter=@repo/business-dashboard",
		"deploy:api": "turbo run deploy --filter=@repo/api",
		"deploy:queue": "turbo run deploy --filter=@repo/queue",
		"deploy:scheduled": "turbo run deploy --filter=@repo/scheduled",
		"deploy:workers": "turbo run deploy --filter=@repo/api --filter=@repo/auth-service --filter=@repo/lpg-service --filter=@repo/booking-service --filter=@repo/queue --filter=@repo/scheduled",
		"deploy:marketing-site": "bun run deploy:marketing-site:staging",
		"deploy:marketing-site:staging": "bun run --filter @repo/marketing-site deploy:staging",
		"deploy:marketing-site:production": "bun run --filter @repo/marketing-site deploy:production",
		"deploy:business-dashboard": "bun run deploy:business-dashboard:staging",
		"deploy:business-dashboard:staging": "bun run --filter @repo/business-dashboard deploy:staging",
		"deploy:business-dashboard:production": "bun run --filter @repo/business-dashboard deploy:production",
		"deploy:sites": "bun run deploy:sites:staging",
		"deploy:sites:staging": "bun run deploy:marketing-site:staging && bun run deploy:business-dashboard:staging",
		"deploy:sites:production": "bun run deploy:marketing-site:production && bun run deploy:business-dashboard:production",
		"deploy:all": "turbo run deploy --filter=@repo/api --filter=@repo/queue --filter=@repo/scheduled --filter=@repo/marketing-site --filter=@repo/business-dashboard",
		"lint": "biome check",
		"lint:fix": "biome check --fix",
		"format": "biome format  --write",
		"format:fix": "biome format --write",
		"check-types": "turbo run check-types",
		"clean:node": "find . -type d -name node_modules -prune -exec rm -rf '{}' +",
		"clean:dist": "find . -type d -name dist -prune -exec rm -rf '{}' +",
		"clean:build": "find . -type d -name build -prune -exec rm -rf '{}' +",
		"clean": "bun run clean:node && bun run clean:dist && bun run clean:build",
		"cli": "bun tools/cli/index.ts",
		"version:bump": "bun run cli version bump",
		"db:migrate": "bun run cli db migrate",
		"db:generate": "bun run cli db generate",
		"db:studio": "bun run cli db studio",
		"db:list": "bun run cli db list",
		"db:seed:dev": "bun run cli db seed --count 100",
		"db:fresh": "bun run cli db fresh",
		"api:test": "turbo run test --filter=@repo/api",
		"queue:test": "turbo run test --filter=@repo/queue",
		"scheduled:test": "turbo run test --filter=@repo/scheduled",
		"marketing-site:test": "turbo run test --filter=@repo/marketing-site",
		"business-dashboard:test": "turbo run test --filter=@repo/business-dashboard",
		"mobile-app:test": "turbo run test --filter=@repo/mobile-app",
		"owner-app:test": "turbo run test --filter=@repo/owner-app",
		"test": "turbo run test"
	},
	"devDependencies": {
		"lightningcss": "1.30.1",
		"@biomejs/biome": "^2.4.16",
		"@types/bun": "^1.3.14",
		"@types/node": "^25.9.1",
		"turbo": "^2.9.16",
		"typescript": "^6.0.3"
	},
	"workspaces": [
		"apps/*",
		"sites/*",
		"workers/*",
		"packages/*",
		"tools/*"
	],
	"overrides": {
		"lightningcss": "1.30.1",
		"@react-native-community/netinfo": "12.0.1"
	}
}
